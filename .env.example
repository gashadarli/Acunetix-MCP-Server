# Acunetix MCP Server Configuration
# Copy this file to .env and fill in your values.

# ── Required ─────────────────────────────────────────────────────────────────

# Full Acunetix API base URL — include /api/v1
# On-premise example:  https://10.0.244.136/api/v1
# Acunetix Online:     https://online.acunetix.com/api/v1
ACUNETIX_BASE_URL=https://10.0.244.136/api/v1

# API key — get it from Acunetix UI → top-right menu → Profile → API Key
ACUNETIX_API_KEY=your-api-key-here

# ── Optional ─────────────────────────────────────────────────────────────────

# SSL verification.
# Set to 'false' if Acunetix uses a self-signed certificate (most on-prem
# installs). Set to 'true' only if you have a valid CA-signed certificate.
VERIFY_SSL=false

# MCP server port — used only with Docker / --http transport.
# Ignored in stdio mode (the default for OpenClaw / Claude Desktop / Cursor).
MCP_SERVER_PORT=8000
