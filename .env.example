# Acunetix MCP Server Configuration
# Copy this file to .env and fill in your values

# ── Required ────────────────────────────────────────────────────────────────

# Full Acunetix API base URL (include /api/v1)
ACUNETIX_BASE_URL=https://10.0.244.136/api/v1

# Acunetix API Key (from Acunetix UI > Profile > API Key)
ACUNETIX_API_KEY=your-api-key-here

# ── Optional ─────────────────────────────────────────────────────────────────

# Set to 'true' only if you have a valid SSL cert (most on-prem installs use self-signed)
VERIFY_SSL=false

# MCP server port (default: 8000)
MCP_SERVER_PORT=8000
